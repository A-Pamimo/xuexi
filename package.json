{
  "name": "xuexi",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "seed:build": "tsx scripts/build-seed/index.ts",
    "audio:build": "tsx scripts/build-audio/index.ts",
    "content:build": "npm run seed:build && npm run audio:build",
    "deps:check": "node scripts/deps-check.mjs"
  },
  "dependencies": {
    "expo": "~57.0.2",
    "expo-asset": "~57.0.3",
    "expo-audio": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-file-system": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "~0.10.0",
    "ts-fsrs": "^5.4.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "better-sqlite3": "^11.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.0"
  },
  "private": true

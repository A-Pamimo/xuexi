# Firebase web config for Google sign-in + cloud history sync.
#
# These are NOT secrets — a Firebase web config is public by design; Firestore
# security rules protect the data. Copy this file to `.env`, paste your project's
# values, and rebuild. Without these set, the app runs fully as a local guest
# (sign-in UI stays hidden). Get the values from the Firebase console:
#   Project settings → General → Your apps → Web app → SDK setup and configuration.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

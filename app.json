{
  "expo": {
    "name": "xuexi",
    "slug": "xuexi",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "xuexi",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0B12",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B12"
    },
    "assetBundlePatterns": [
      "assets/db/**",
      "assets/audio/**",
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xuexi.app"
    },
    "android": {
      "package": "com.xuexi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6E4DF0"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-av",
        { "microphonePermission": false }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/xuexi"
    }
  }
}
